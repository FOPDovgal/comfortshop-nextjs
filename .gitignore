# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local

# Google service account credentials — must never be committed
*-service-account.json
comfortshop-182219*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# user-uploaded images (kept on server, not in git)
/public/uploads/*
!/public/uploads/.gitkeep
